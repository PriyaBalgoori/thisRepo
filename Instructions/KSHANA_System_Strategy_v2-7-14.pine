 -0.050831 ? (gLR <= 2.418675 ? 0 : 0) : (gLRV <= 1.188506 ? 0 : 7)) : (dgLR <= -0.162273 ? (dgLR <= -0.210853 ? 0 : 0) : (gV <= 6.542371 ? 7 : 7)))) : (gLRV <= 0.483989 ? (gV <= 1.374629 ? (gLR <= 0.032042 ? 7 : (gLR <= 0.101277 ? 7 : 7)) : (dgLR <= 0.158498 ? (gLRV <= 0.195641 ? 0 : 5) : (gLR <= 2.382193 ? 7 : 5))) : (gLR <= 0.086682 ? (dgLR <= 0.164388 ? 0 : 0) : (gLR <= 1.783321 ? (dgLR <= 0.582278 ? 7 : 7) : (dgLR <= 0.120538 ? 7 : 7))))))))
