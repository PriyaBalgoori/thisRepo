// AUTO-GENERATED direction tree (depth-8, 123 leaves) — EXACT 1:1, ~82% dir OOS. DRIVES SIGNALS.
mirror_dir(v1, gLR, dgLR, gV, gLRV, stack) =>
    int _d = (v1 <= 0.001324 ? (gLR <= 0.333492 ? (dgLR <= -0.040963 ? (gLR <= -0.028824 ? (gLR <= -2.423553 ? (gLRV <= 0.246507 ? (dgLR <= -0.260758 ? (gV <= -5.096389 ? -1 : -1) : (gLRV <= -0.536368 ? -1 : 0)) : 0) : (dgLR <= -0.112397 ? (dgLR <= -1.057245 ? -1 : (dgLR <= -0.158309 ? -1 : -1)) : (gLRV <= -0.917781 ? (gLRV <= -1.402784 ? -1 : -1) : (gLR <= -0.331942 ? -1 : -1)))) : (gLRV <= -0.017280 ? (gLR <= 0.139877 ? (gV <= -0.552808 ? 0 : 0) : (gV <= -0.030654 ? 0 : 0)) : (dgLR <= -0.140464 ? (gLRV <= 0.428840 ? (gLR <= 0.116460 ? -1 : 0) : (gLR <= 0.143190 ? -1 : -1)) : (gLRV <= 0.672737 ? 0 : (gV <= 1.302776 ? -1 : -1))))) : (gLR <= -2.605377 ? (gLRV <= -2.226102 ? -1 : (v1 <= -0.246111 ? 0 : (gLR <= -3.641583 ? 0 : (gLR <= -3.260779 ? 0 : 0)))) : (v1 <= -0.025102 ? (gLR <= -0.024982 ? (gLR <= -1.204935 ? (gLRV <= -0.632179 ? -1 : 0) : (gV <= -1.825556 ? -1 : -1)) : 0) : (gLR <= -1.690914 ? 0 : (gLR <= 0.012433 ? (gLRV <= -0.606894 ? 0 : 0) : 0))))) : (gLR <= 0.870196 ? (gLRV <= 0.872383 ? (gLRV <= 0.377101 ? (gLR <= 0.406781 ? (gLR <= 0.374298 ? 0 : 0) : 0) : (gLR <= 0.494897 ? (v1 <= -0.148546 ? 0 : 0) : (gLR <= 0.635755 ? (gV <= 1.253126 ? 0 : 0) : 0))) : (gLRV <= 1.685122 ? (dgLR <= -0.109654 ? (gLR <= 0.697220 ? (dgLR <= -0.280072 ? -1 : -1) : 0) : 0) : (gLRV <= 2.187333 ? -1 : -1))) : (gLRV <= 2.558525 ? (gLRV <= 1.722012 ? (gLR <= 0.899253 ? 0 : (gLR <= 0.979319 ? (gLR <= 0.946384 ? 0 : 0) : 0)) : (gLR <= 1.367131 ? 0 : 0)) : 0))) : (gLR <= -0.179519 ? (gLR <= -0.791235 ? (gLRV <= -1.603181 ? (gLR <= -1.239978 ? (gLRV <= -2.429182 ? 0 : 0) : 1) : (gLR <= -0.951230 ? (gLRV <= -1.540384 ? 0 : 0) : (gLRV <= -0.937361 ? 0 : 0))) : (gLRV <= -0.579890 ? (v1 <= 0.083598 ? (dgLR <= 0.083074 ? 0 : 0) : (gLR <= -0.490202 ? (gLRV <= -0.973177 ? (gV <= -2.132375 ? 1 : 1) : 0) : (v1 <= 0.182948 ? 1 : (gV <= -1.355143 ? 1 : 1)))) : (gLRV <= -0.057526 ? (gLR <= -0.367300 ? (gLR <= -0.570390 ? 0 : 0) : (dgLR <= 0.214427 ? 0 : 1)) : (gLR <= -0.312286 ? 0 : (v1 <= 0.179917 ? 0 : 0))))) : (dgLR <= 0.075021 ? (gLR <= 1.233629 ? (gLR <= 0.118372 ? (gLRV <= 0.541845 ? (gLR <= -0.073455 ? 0 : 0) : 0) : (v1 <= 0.069129 ? (gLRV <= 0.264044 ? (gLR <= 0.800597 ? 0 : 0) : (gV <= 1.502705 ? 1 : 0)) : (gLR <= 0.916334 ? (gLR <= 0.367086 ? 1 : 1) : (gV <= 1.555659 ? 0 : 1)))) : (v1 <= 0.091699 ? (gLRV <= 0.350884 ? (gV <= 1.446134 ? 0 : 0) : (gLR <= 2.530461 ? (gLRV <= 1.554520 ? 0 : 1) : (v1 <= 0.056292 ? 0 : 0))) : (gLRV <= 1.177618 ? (dgLR <= 0.043368 ? (gLR <= 2.543312 ? 0 : 0) : (v1 <= 0.193908 ? 1 : 1)) : (gLR <= 2.297031 ? (gLR <= 1.583621 ? 1 : 1) : (v1 <= 0.227198 ? 0 : 1))))) : (gLR <= -0.032958 ? (gV <= -0.279826 ? (gLRV <= -0.628052 ? (gLR <= -0.119502 ? 1 : 1) : 1) : (dgLR <= 0.225611 ? 0 : 0)) : (gLR <= 1.592038 ? (gLR <= 0.157178 ? (gLRV <= 0.681245 ? (v1 <= 0.116332 ? 1 : 1) : 0) : (dgLR <= 0.666630 ? (gLRV <= 1.184355 ? 1 : 1) : (gLRV <= 0.518034 ? 1 : 1))) : (dgLR <= 0.117371 ? (gV <= 3.310918 ? (gV <= 2.405695 ? 1 : 0) : 1) : (dgLR <= 1.039367 ? (dgLR <= 0.288718 ? 1 : 1) : 1)))))))
    _d

// ─── mirror rating on a series ──────────────────────────────
calc_rating()=>
    L=tema(close,ss_len)
    LR=ta.ema(close,lr_len)
    V=ta.ema(close,v_len)
    a=ta.atr(atr_len)
    Lp1=L[1]
    v1  = a>0 ? (L-Lp1)/a : 0.0
    gLR = a>0 ? (L-LR)/a : 0.0
    dgLR= gLR - (a>0 ? (Lp1-LR[1])/a : 0.0)
    gV  = a>0 ? (L-V)/a : 0.0
    gLRV= a>0 ? (LR-V)/a : 0.0
    stack = (L>LR and LR>V) ? 1 : ((L<LR and LR<V) ? -1 : 0)
    mirror_rating(v1,gLR,dgLR,gV,gLRV,stack)

// features + DIRECTION (mirror_dir) — this is what the indicator uses to drive B/S signals
calc_dir()=>
    L=tema(close,ss_len)
    LR=ta.ema(close,lr_len)
    V=ta.ema(close,v_len)
    a=ta.atr(atr_len)
    Lp1=L[1]
    v1  = a>0 ? (L-Lp1)/a : 0.0
    gLR = a>0 ? (L-LR)/a : 0.0
    dgLR= gLR - (a>0 ? (Lp1-LR[1])/a : 0.0)
    gV  = a>0 ? (L-V)/a : 0.0
    gLRV= a>0 ? (LR-V)/a : 0.0
    stack = (L>LR and LR>V) ? 1 : ((L<LR and LR<V) ? -1 : 0)
    mirror_dir(v1,gLR,dgLR,gV,gLRV,stack)

dir_of(r)=> r>0 ? 1 : r<0 ? -1 : 0

// current instrument
// ★ AUTO-DETECT. Order matters: check the LONGEST/most specific tickers first, and check RTY before
//   ES etc. Works on micros too (MNQ contains "NQ", MYM contains "YM", MCL contains "CL", MGC->"GC").
//   Anything unrecognised falls back to "NQ" (flip exit, trail off) — safe, but the label will lie,
//   so ZB/ZN are listed explicitly. If you trade a NEW market, ADD IT HERE.
inst = inst_ovr=="AUTO" ? (str.contains(syminfo.ticker,"RTY")?"RTY": str.contains(syminfo.ticker,"NQ")?"NQ": str.contains(syminfo.ticker,"YM")?"YM": str.contains(syminfo.ticker,"ZB")?"ZB": str.contains(syminfo.ticker,"ZN")?"ZN": str.contains(syminfo.ticker,"CL")?"CL": str.contains(syminfo.ticker,"GC")?"GC": str.contains(syminfo.ticker,"NG")?"NG": str.contains(syminfo.ticker,"SI")?"SI": str.contains(syminfo.ticker,"ES")?"ES":"NQ") : inst_ovr

// per-instrument trail (ATR mult); 0 = flip (no trail)
trail_mult = inst=="NG"?5.0 : inst=="GC"?8.0 : inst=="ES"?8.0 : 0.0

// ─── 5m DIRECTION + 15m DIRECTION (both from mirror_dir, exactly like the v3 indicator) ──
// r5/rW (rating) are kept for bar-coloring only. SIGNALS come from dir_now / wave_dir (mirror_dir).
r5 = calc_rating()
dir_now = calc_dir()
// 15m WAVE direction via mirror_dir on the 15m timeframe (matches indicator's wave_dir).
// lookahead_off = causal (no future peek). No [1]: uses developing 15m, exactly as the indicator.
wave_dir = request.security(syminfo.tickerid, wave_tf, calc_dir(), lookahead=barmerge.lookahead_off)
d5 = dir_now
dW = wave_dir

// ─── entry signal: dir_now zone change, aligned with 15m dir (EXACT indicator logic) ──
var int prev_zone=0
bool raw_long  = dir_now==1  and prev_zone!=1
bool raw_short = dir_now==-1 and prev_zone!=-1
if dir_now!=0
    prev_zone:=dir_now
bool aligned_long  = raw_long  and wave_dir==1
bool aligned_short = raw_short and wave_dir==-1

// ─── session timing (ET) ────────────────────────────────────
et_hr = hour(time,"America/New_York")
et_min = minute(time,"America/New_York")
mins = et_hr*60+et_min
in_gap = mins>=16*60+45 and mins<18*60

// REGIME GATE REMOVED: the day-after-trend gate depended on pulling 4 index feeds onto every
// chart and did not reproduce reliably live (over-skipped on GC: 34 live vs 53 backtest trades).
// It also hurt the indices and clashed with discretionary same-day trading. Dropped by decision
// 2026-07-09. Each chart now trades purely on its own 5m+15m signals + its own exit.
regime_ok = true

// only trade within the validated window (and forward). Before start_date = warmup only, no trades.
in_window = not use_startdate or time >= start_date

// ─── session flat window ────────────────────────────────────
force_flat = use_session and in_gap
can_enter = not force_flat and regime_ok and in_window

// ─── trailing stop state ────────────────────────────────────
var float entry_px=na
var float peak_fav=0.0
atrv = ta.atr(atr_len)
if strategy.position_size!=0
    fav = (close-entry_px)*math.sign(strategy.position_size)
    peak_fav := math.max(peak_fav, fav)

// ─── ★ ATR-EQUAL-RISK POSITION SIZING ───────────────────────
// $ risk of a 1-ATR adverse move, for ONE contract of whatever this chart is.
// syminfo.pointvalue is TV's live contract multiplier — NEVER hardcode it (the SI 100x bug).
// On a MICRO chart (MNQ/MYM/MGC/MCL) pointvalue is 1/10th, so this naturally returns ~10x the
// contracts for the same dollar risk. Micros are how a small account achieves true equal-risk.
// nz() guards: if atrv is na (warmup), qty would be na and TV DROPS THE ORDER SILENTLY.
float dollar_per_atr = nz(atrv) * syminfo.pointvalue
float raw_ct  = dollar_per_atr > 0 ? risk_per_trade / dollar_per_atr : 1.0
int   sized_ct = int(math.max(min_ct, math.min(max_ct, math.round(nz(raw_ct, 1.0)))))
int   pos_qty  = math.max(1, use_atr_size ? sized_ct : fixed_ct)
// true dollar risk actually being taken (after rounding + caps) — display this, don't trust the input
float true_risk = pos_qty * dollar_per_atr
bool  cap_bound = use_atr_size and raw_ct > max_ct   // size is being clipped -> not truly equal-risk

// ─── ORDERS ─────────────────────────────────────────────────
// CrossTrade command builder. Format = semicolon-terminated key=value pairs (NOT json).
// Entries/flips use PLACE with action=buy/sell. Exits use a flatten. Strategy Sync (optional)
// appends the strategy's intended market position so CrossTrade can self-correct desyncs.
ct_sym = ct_symbol=="" ? syminfo.ticker : ct_symbol
// TradingView strategy position-state placeholders resolve at alert time (used by Strategy Sync):
// ★ EXACT CrossTrade format (verified against crosstrade.io docs 2026-07-12). Every field matters:
//   key=          <- YOUR SECRET KEY. Missing => "Secret key missing, invalid, or inactive".
//   command=place <- REQUIRED. Missing => "Improperly formatted request".
//   qty=          <- it is "qty", NOT "quantity".
//   tif=day       <- time in force.
//   Strategy Sync tail lets CrossTrade compare intended vs actual position and self-correct.
// ★★★ VERIFIED AGAINST crosstrade.io DOCS 2026-07-13. DO NOT "IMPROVE" THIS. ★★★
//
// ██ WHY THERE IS NO STRATEGY SYNC ██
//   CrossTrade FAQ, verbatim: "If you're running a stop-and-reverse strategy (constantly flipping
//   long<->short without going flat), you CAN'T use Strategy Sync because the position never reaches
//   flat. For S&R strategies, remove the sync logic and use flatten_first=true; instead."
//   **THIS SYSTEM IS STOP-AND-REVERSE.** It flips long<->short and only goes flat at 16:45.
//   Strategy Sync could NEVER have worked here. I burned several of CK's cycles patching sync fields
//   one at a time ({{placeholders}} unresolved -> market_position_size unknown -> ...). The whole
//   mechanism was wrong for this strategy type. flatten_first is the documented answer.
//
// ██ WHY flatten_first=true IS EXACTLY WHAT WE NEED ██
//   On a FLIP: closes the entire opposite position, THEN opens the new one. This also solves the
//   size-changing flip for free (long 7 MYM -> short 7: it closes all 7, then opens 7 short).
//   On a FRESH entry from flat: nothing to close, just opens. Correct in both cases.
//
// ██ WHY closeposition AND NOT flatten ██
//   `command=flatten` flattens ALL positions across ALL accounts and broker connections. That would
//   have wiped every other position CK holds. For ONE instrument the correct command is CLOSEPOSITION.
//
// ██ REQUIRED PLACE FIELDS (docs): key, command, account, instrument, action, qty, order_type, tif ██
//   Field names are exact: qty (NOT quantity), order_type (NOT ordertype). Semicolon after EVERY field.
place_cmd(_action, _qty) =>
    "key=" + ct_key + "; command=place; account=" + ct_account + "; instrument=" + ct_sym + "; action=" + _action + "; qty=" + str.tostring(_qty) + "; order_type=market; tif=day; flatten_first=true;"
flat_cmd() =>
    "key=" + ct_key + "; command=closeposition; account=" + ct_account + "; instrument=" + ct_sym + ";"

// exits first
// 1. session force-flat
if force_flat and strategy.position_size!=0
    strategy.close_all("session 4:45", alert_message=flat_cmd())
// 2. trailing stop (grinders only)
if use_trail and trail_mult>0 and strategy.position_size!=0 and atrv>0
    fav=(close-entry_px)*math.sign(strategy.position_size)
    if peak_fav>=trail_mult*atrv and (peak_fav-fav)>=trail_mult*atrv
        strategy.close_all("trail", alert_message=flat_cmd())

// entries & flips
// FLIP (reversal) must ALWAYS execute regardless of regime — closing/reversing an existing
// position is an EXIT action, not a new bet. Regime gate only blocks FRESH entries when flat.
// This matches the backtest (stop-and-reverse always-in; regime filters entry selection only).
bool have_long  = strategy.position_size>0
bool have_short = strategy.position_size<0
bool flat       = strategy.position_size==0

// reversal: opposite signal while in a position -> always allowed (unless in the 4:45-6:00 flat gap)
// NOTE ON FLIPS + VARIABLE SIZE: strategy.entry() in the opposite direction auto-reverses; the qty
// given is the NEW position size and Pine closes the old leg itself. NinjaTrader must therefore
// trade (old_size + new_size). CrossTrade's Strategy Sync reconciles this using the market_position
// placeholders in sync_tail(). KEEP STRATEGY SYNC ON and SIM-TEST A FLIP before going live.
// ★★★ WHY strategy.order() AND NOT strategy.entry() ★★★
//   PROVEN BY THE TV REPORT (NQ1!, 2026-07-12): passing an EXPLICIT qty to strategy.entry() does NOT
//   behave like the default. Even with pos_qty==1 — identical to default_qty_value=1 — v2 produced
//   58 trades vs v1's 73. Pine's reversal path with an explicit qty trades only `qty` contracts, so
//   short-1 + entry(long, qty=1) leaves you FLAT instead of LONG 1. The position state then desyncs
//   and every subsequent flip silently disappears. The 15 missing trades were ALL rapid flip
//   sequences (e.g. 05-25: v1 flipped 4x in 4h, v2 took NONE of them).
//   strategy.order() does ZERO position management — it places exactly the contracts you ask for.
//   We compute the delta ourselves, so a reversal is unambiguous by construction.
//       to reach +pos_qty from cur:  BUY  (pos_qty - cur)     [cur<0 when short -> buys MORE]
//       to reach -pos_qty from cur:  SELL (pos_qty + cur)     [cur>0 when long  -> sells MORE]
// ★ FLATTEN, THEN ENTER. pyramiding=0. This is the only structure that is BOTH correct on
//   reversals AND keeps exactly one position open.
//   WHAT FAILED AND WHY (all measured on NQ1!, keep this so nobody repeats it):
//     a) strategy.entry(qty=N) alone            -> 58 trades. Explicit qty breaks Pine's reversal:
//        short 1 + entry(long,qty=1) trades only 1 -> leaves you FLAT, not long. State desyncs and
//        every fast flip afterwards silently vanishes.
//     b) strategy.order(delta) + pyramiding=10  -> 79 trades. Reversal works, but TV splits each one
//        into TWO independent positions (qty 1 AND qty 2 on the SAME bar, exiting separately). You
//        end up holding 3 contracts, not 2, and the P&L is INFLATED. ($185k was fake.)
//     c) THIS: close_all() then entry(qty)      -> flatten is unambiguous, the entry opens exactly
//        pos_qty, and pyramiding=0 guarantees a single position.
bool go_long  = in_window and not force_flat and aligned_long  and (have_short or (flat and can_enter))
bool go_short = in_window and not force_flat and aligned_short and (have_long  or (flat and can_enter))

if go_long
    if have_short
        strategy.close_all(alert_message=flat_cmd())   // EVERY order must carry a valid command
    strategy.entry("L", strategy.long, qty=pos_qty, alert_message=place_cmd("buy", pos_qty))
    entry_px:=close
    peak_fav:=0.0
else if go_short
    if have_long
        strategy.close_all(alert_message=flat_cmd())   // EVERY order must carry a valid command
    strategy.entry("S", strategy.short, qty=pos_qty, alert_message=place_cmd("sell", pos_qty))
    entry_px:=close
    peak_fav:=0.0

// ─── visuals ────────────────────────────────────────────────
col = r5==7?#2962ff:r5==5?#26a69a:r5==3?#c0ca33:r5==0?#ff9800:r5==-3?#f48fb1:r5==-5?#e040fb:#ff1744
barcolor(col)
plotshape(aligned_long and can_enter,"L",shape.triangleup,location.belowbar,color.new(#26a69a,0),size=size.small)
plotshape(aligned_short and can_enter,"S",shape.triangledown,location.abovebar,color.new(#ff1744,0),size=size.small)
// info table
var table T=table.new(position.top_right,2,8,border_width=1,bgcolor=color.new(#0d1b2a,0),frame_color=color.gray,frame_width=1)
if barstate.islast
    c_lbl=color.new(#9fb3c8,0)
    c_val=color.new(color.white,0)
    c_hdr=color.new(#1F4E78,0)
    table.cell(T,0,0,"Instrument",text_size=size.small,text_color=c_val,bgcolor=c_hdr)
    table.cell(T,1,0,inst+(trail_mult>0?(" (trail "+str.tostring(trail_mult)+")"):" (flip)"),text_size=size.small,text_color=c_val,bgcolor=c_hdr)
    table.cell(T,0,1,"5m / 15m",text_size=size.small,text_color=c_lbl,bgcolor=color.new(#0d1b2a,0))
    table.cell(T,1,1,(d5>0?"B":d5<0?"S":"N")+" / "+(dW>0?"B":dW<0?"S":"N"),text_size=size.small,text_color=c_val,bgcolor=color.new(#0d1b2a,0))
    table.cell(T,0,2,"Signal",text_size=size.small,text_color=c_lbl,bgcolor=color.new(#0d1b2a,0))
    table.cell(T,1,2,aligned_long?"BUY setup":aligned_short?"SELL setup":"—",text_size=size.small,text_color=c_val,bgcolor=color.new(#0d1b2a,0))
    table.cell(T,0,3,"Session",text_size=size.small,text_color=c_lbl,bgcolor=color.new(#0d1b2a,0))
    table.cell(T,1,3,force_flat?"FLAT 4:45-6":in_window?"active":"pre-window",text_size=size.small,text_color=c_val,bgcolor=color.new(#0d1b2a,0))
    table.cell(T,0,4,"Position",text_size=size.small,text_color=c_lbl,bgcolor=color.new(#0d1b2a,0))
    table.cell(T,1,4,strategy.position_size>0?"LONG":strategy.position_size<0?"SHORT":"flat",text_size=size.small,text_color=strategy.position_size>0?color.new(color.green,0):strategy.position_size<0?color.new(color.red,0):c_val,bgcolor=color.new(#0d1b2a,0))
    table.cell(T,0,5,"Net P&L",text_size=size.small,text_color=c_lbl,bgcolor=color.new(#0d1b2a,0))
    table.cell(T,1,5,"$"+str.tostring(strategy.netprofit,"#"),text_size=size.small,text_color=strategy.netprofit>=0?color.new(color.green,0):color.new(color.red,0),bgcolor=color.new(#0d1b2a,0))
    // ★ SIZING ROWS — watch these. If SIZE is always at the cap, your risk-per-trade is too high
    //   for this instrument (or you should be on micros). If true risk is far from your input, the
    //   rounding/cap is biting and you are NOT running true equal-risk.
    table.cell(T,0,6,"Size (next)",text_size=size.small,text_color=c_lbl,bgcolor=color.new(#0d1b2a,0))
    // ★ DEAD SIMPLE. No ternary colors, no conditional concatenation, no format strings.
    //   The fancy version (cap_bound ? orange : white, " CAP!" suffix) KILLED THE TABLE at
    //   runtime whenever risk_per_trade changed. Cosmetics are not worth a broken dashboard.
    string sz_txt = str.tostring(pos_qty) + " ct"
    table.cell(T,1,6,sz_txt,text_size=size.small,text_color=c_val,bgcolor=color.new(#0d1b2a,0))
    table.cell(T,0,7,"$/ATR | risk $",text_size=size.small,text_color=c_lbl,bgcolor=color.new(#0d1b2a,0))
    string rk_txt = str.tostring(math.round(dollar_per_atr)) + " / " + str.tostring(math.round(true_risk))
    table.cell(T,1,7,rk_txt,text_size=size.small,text_color=c_val,bgcolor=color.new(#0d1b2a,0))

// ─── ★ TEST FIRE — proves the LIVE order path without waiting for a 5m+15m alignment ───────────
//   Fires a REAL strategy.entry, so it carries alert_message exactly like a production signal.
//   Guard: only when FLAT and only on the latest confirmed bar -> fires once, in real time only.
//   The 16:45 force-flat will close it, which also tests the CLOSEPOSITION path. TURN IT OFF AFTER.
if test_fire and barstate.islast and barstate.isconfirmed and strategy.position_size == 0
    strategy.entry("L", strategy.long, qty=pos_qty, alert_message=place_cmd("buy", pos_qty))
